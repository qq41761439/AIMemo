NODE_ENV=development
HOST=127.0.0.1
PORT=8787
DATA_STORE=memory
# Set DATA_STORE=prisma and run `npm run db:up && npm run prisma:push`
# when you want persistent backend users, tasks, summaries, and quotas.
DATABASE_URL=postgresql://aimemo:aimemo@localhost:5432/aimemo
AUTH_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
EMAIL_CODE_TTL_MINUTES=10
FREE_MONTHLY_SUMMARY_LIMIT=30
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace-with-real-provider-key
LLM_MODEL=deepseek-v4-flash
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_APP_SECRET=
